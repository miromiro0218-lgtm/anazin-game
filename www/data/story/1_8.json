  {
    "bg": "images/bg/abandoned_building_stairs.jpg",
    "left": "images/characters/ebihara.png",
    "right": "images/characters/yuto.png",
    "active": "left",
    "speaker": "海老原",
    "text": "ここ、ちょっと安全そうか……？"
