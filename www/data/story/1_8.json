  {
    "bg": "images/bg/abandoned_building_outside.jpg",
    "left": "images/characters/yuto.png",
    "right": "images/characters/kohei.png",
    "active": "",
    "speaker": "",
    "text": "井口は膝をつき、深く息を吸った。胸の奥に宿る鶴野の力が、まだ熱を帯びて疼いている。"
  },
  {
    "bg": "images/bg/abandoned_building_outside.jpg",
    "left": "images/characters/kohei.png",
    "right": "images/characters/yuto.png",
    "active": "left",
    "speaker": "明日木",
    "text": "井口……大丈夫か？"
